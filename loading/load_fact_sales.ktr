    <quoteString>N</quoteString>
    <sql>UPDATE ETL_CONTROL
SET LastSuccessfulLoad = NOW(),
    LastRunStatus      = 'SUCCESS',
    LastRunAt          = NOW()
WHERE ProcessName = 'FACT_SALES'</sql>
