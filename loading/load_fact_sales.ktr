  <!-- ============================================================ -->
  <!-- STEP 9: Lookup if fact row already exists                     -->
  <!-- Compound key: (SourceOrderID, SourceArticleID)                -->
  <!-- Returns NULL if not found → new row                           -->
  <!-- ============================================================ -->
  <step>
    <name>lookup_fact_exists</name>
    <type>DBLookup</type>
    <description/>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <connection>warehouse</connection>
    <cache>Y</cache>
    <cache_load_all>N</cache_load_all>
    <cache_size>0</cache_size>
    <lookup>
      <schema/>
      <table>FACT_SALES</table>
      <orderby/>
      <fail_on_multiple>N</fail_on_multiple>
      <eat_row_on_failure>N</eat_row_on_failure>
      <key>
        <name>SourceOrderID</name>
        <field>SourceOrderID</field>
        <condition>=</condition>
        <name2/>
