  <!-- ============================================================ -->
  <!-- STEP 1: Read last successful load from ETL_CONTROL            -->
  <!-- ============================================================ -->
  <step>
    <name>get_last_load</name>
    <type>TableInput</type>
    <description/>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <connection>warehouse</connection>
    <sql>SELECT
  IFNULL(LastSuccessfulLoad,
         CAST('1900-01-01 00:00:00' AS DATETIME)) AS last_load
FROM ETL_CONTROL
WHERE ProcessName = 'FACT_SALES'</sql>
    <limit>0</limit>
    <lookup/>
    <execute_each_row>N</execute_each_row>
    <variables_active>N</variables_active>
    <lazy_conversion_active>N</lazy_conversion_active>
    <cached_row_meta_active>N</cached_row_meta_active>
    <row-meta>
    </row-meta>
    <attributes/>
    <cluster_schema/>
    <remotesteps>
      <input>
      </input>
      <output>
      </output>
    </remotesteps>
    <GUI>
      <xloc>80</xloc>
      <yloc>150</yloc>
      <draw>Y</draw>
    </GUI>
  </step>

  <!-- ============================================================ -->
  <!-- STEP 2: Extract wide sales rows from OLTP                     -->
  <!-- Grain = 1 STAVKA row                                          -->
  <!-- Age group label is computed in SQL                             -->
  <!-- ============================================================ -->
  <step>
    <name>extract_sales</name>
    <type>TableInput</type>
    <description/>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <connection>oltp</connection>
    <sql>SELECT
  s.IdNar                          AS SourceOrderID,
  s.IdArt                          AS SourceArticleID,
  s.Kolicina                       AS QuantitySold,
  s.Iznos                          AS SalesAmount,
  n.Datum                          AS OrderDate,
  buyer.Pol                        AS BuyerGenderCode,
  CASE
    WHEN (YEAR(n.Datum) - buyer.Godiste) &lt; 18 THEN '&lt;18'
    WHEN (YEAR(n.Datum) - buyer.Godiste) BETWEEN 18 AND 25 THEN '18-25'
    WHEN (YEAR(n.Datum) - buyer.Godiste) BETWEEN 26 AND 35 THEN '26-35'
    WHEN (YEAR(n.Datum) - buyer.Godiste) BETWEEN 36 AND 45 THEN '36-45'
    WHEN (YEAR(n.Datum) - buyer.Godiste) BETWEEN 46 AND 60 THEN '46-60'
    ELSE '60+'
  END                              AS BuyerAgeGroupLabel,
  buyer.IdM                        AS BuyerPlaceSourceID,
  seller.IdM                       AS SellerPlaceSourceID,
  s.CreatedAt                      AS SourceCreatedAt
FROM STAVKA s
JOIN NARUDZBINA n    ON s.IdNar = n.IdNar
JOIN ARTIKAL a       ON s.IdArt = a.IdArt
JOIN KORISNIK buyer  ON n.IdKor = buyer.IdKor
JOIN KORISNIK seller ON a.IdKor = seller.IdKor
WHERE s.CreatedAt > ?</sql>
    <limit>0</limit>
    <lookup>get_last_load</lookup>
    <execute_each_row>Y</execute_each_row>
    <variables_active>N</variables_active>
    <lazy_conversion_active>N</lazy_conversion_active>
    <cached_row_meta_active>N</cached_row_meta_active>
    <row-meta>
    </row-meta>
    <attributes/>
    <cluster_schema/>
    <remotesteps>
      <input>
      </input>
      <output>
      </output>
    </remotesteps>
    <GUI>
      <xloc>250</xloc>
      <yloc>150</yloc>
      <draw>Y</draw>
    </GUI>
  </step>

  <!-- ============================================================ -->
  <!-- STEP 3: Lookup TimeKey from DIM_TIME by OrderDate             -->
  <!-- ============================================================ -->
  <step>
    <name>lookup_time</name>
    <type>DBLookup</type>
    <description/>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <connection>warehouse</connection>
    <cache>Y</cache>
    <cache_load_all>N</cache_load_all>
    <cache_size>0</cache_size>
    <lookup>
      <schema/>
      <table>DIM_TIME</table>
      <orderby/>
      <fail_on_multiple>N</fail_on_multiple>
      <eat_row_on_failure>N</eat_row_on_failure>
      <key>
        <name>OrderDate</name>
        <field>FullDate</field>
        <condition>=</condition>
        <name2/>
      </key>
      <value>
        <name>TimeKey</name>
        <rename>TimeKey</rename>
        <default>0</default>
        <type>Integer</type>
      </value>
    </lookup>
    <attributes/>
    <cluster_schema/>
    <remotesteps>
      <input>
      </input>
      <output>
      </output>
    </remotesteps>
    <GUI>
      <xloc>420</xloc>
      <yloc>150</yloc>
      <draw>Y</draw>
    </GUI>
  </step>

