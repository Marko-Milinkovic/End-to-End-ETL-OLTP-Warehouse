      <enabled>Y</enabled>
    </hop>
  </order>

  <!-- ============================================================ -->
  <!-- STEP 1: Read last successful load from ETL_CONTROL            -->
  <!-- ============================================================ -->
  <step>
    <name>get_last_load</name>
    <type>TableInput</type>
    <description/>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <connection>warehouse</connection>
    <sql>SELECT
  IFNULL(LastSuccessfulLoad,
         CAST('1900-01-01 00:00:00' AS DATETIME)) AS last_load
FROM ETL_CONTROL
WHERE ProcessName = 'FACT_REVIEWS'</sql>
    <limit>0</limit>
    <lookup/>
    <execute_each_row>N</execute_each_row>
    <variables_active>N</variables_active>
    <lazy_conversion_active>N</lazy_conversion_active>
    <cached_row_meta_active>N</cached_row_meta_active>
    <row-meta>
    </row-meta>
    <attributes/>
    <cluster_schema/>
    <remotesteps>
      <input>
      </input>
      <output>
      </output>
    </remotesteps>
    <GUI>
      <xloc>80</xloc>
      <yloc>150</yloc>
      <draw>Y</draw>
    </GUI>
  </step>

  <!-- ============================================================ -->
  <!-- STEP 2: Extract review rows from OLTP                         -->
  <!-- Grain = 1 RECENZIJA row                                       -->
  <!-- Age group label computed in SQL                                -->
  <!-- ============================================================ -->
  <step>
    <name>extract_reviews</name>
    <type>TableInput</type>
    <description/>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <connection>oltp</connection>
    <sql>SELECT
  r.IdKor                          AS SourceReviewerID,
  r.IdArt                          AS SourceArticleID,
  r.Datum                          AS ReviewDate,
  r.Vreme                          AS ReviewTime,
  r.Ocena                          AS Rating,
  r.Ocena                          AS MinRating,
  r.Ocena                          AS MaxRating,
  1                                AS ReviewCount,
  a.IdKor                          AS SourceSellerID,
  reviewer.Pol                     AS BuyerGenderCode,
  CASE
    WHEN (YEAR(r.Datum) - reviewer.Godiste) &lt; 18 THEN '&lt;18'
    WHEN (YEAR(r.Datum) - reviewer.Godiste) BETWEEN 18 AND 25 THEN '18-25'
    WHEN (YEAR(r.Datum) - reviewer.Godiste) BETWEEN 26 AND 35 THEN '26-35'
    WHEN (YEAR(r.Datum) - reviewer.Godiste) BETWEEN 36 AND 45 THEN '36-45'
    WHEN (YEAR(r.Datum) - reviewer.Godiste) BETWEEN 46 AND 60 THEN '46-60'
    ELSE '60+'
  END                              AS BuyerAgeGroupLabel,
  reviewer.IdM                     AS BuyerPlaceSourceID,
  seller.IdM                       AS SellerPlaceSourceID,
  r.CreatedAt                      AS SourceCreatedAt
FROM RECENZIJA r
JOIN ARTIKAL a           ON r.IdArt = a.IdArt
JOIN KORISNIK reviewer   ON r.IdKor = reviewer.IdKor
JOIN KORISNIK seller     ON a.IdKor = seller.IdKor
WHERE r.CreatedAt > ?</sql>
    <limit>0</limit>
    <lookup>get_last_load</lookup>
    <execute_each_row>Y</execute_each_row>
    <variables_active>N</variables_active>
    <lazy_conversion_active>N</lazy_conversion_active>
    <cached_row_meta_active>N</cached_row_meta_active>
    <row-meta>
    </row-meta>
    <attributes/>
    <cluster_schema/>
    <remotesteps>
      <input>
      </input>
      <output>
      </output>
    </remotesteps>
    <GUI>
      <xloc>240</xloc>
      <yloc>150</yloc>
      <draw>Y</draw>
    </GUI>
  </step>

  <!-- ============================================================ -->
  <!-- STEP 3: Lookup TimeKey from DIM_TIME by ReviewDate            -->
  <!-- ============================================================ -->
  <step>
    <name>lookup_time</name>
    <type>DBLookup</type>
    <description/>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <connection>warehouse</connection>
    <cache>Y</cache>
    <cache_load_all>N</cache_load_all>
    <cache_size>0</cache_size>
    <lookup>
      <schema/>
      <table>DIM_TIME</table>
      <orderby/>
      <fail_on_multiple>N</fail_on_multiple>
      <eat_row_on_failure>N</eat_row_on_failure>
      <key>
        <name>ReviewDate</name>
        <field>FullDate</field>
        <condition>=</condition>
        <name2/>
      </key>
      <value>
        <name>TimeKey</name>
        <rename>TimeKey</rename>
        <default>0</default>
        <type>Integer</type>
      </value>
    </lookup>
    <attributes/>
    <cluster_schema/>
    <remotesteps>
      <input>
      </input>
      <output>
      </output>
    </remotesteps>
    <GUI>
      <xloc>400</xloc>
      <yloc>150</yloc>
      <draw>Y</draw>
    </GUI>
  </step>

