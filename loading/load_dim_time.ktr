  <!-- ============================================================ -->
  <!-- HOPS (execution order)                                        -->
  <!-- ============================================================ -->
  <order>
    <hop>
      <from>get_last_load</from>
      <to>extract_dates</to>
      <enabled>Y</enabled>
    </hop>
    <hop>
      <from>extract_dates</from>
      <to>insert_update_dim_time</to>
      <enabled>Y</enabled>
    </hop>
    <hop>
      <from>insert_update_dim_time</from>
      <to>update_etl_control</to>
      <enabled>Y</enabled>
    </hop>
  </order>

  <!-- ============================================================ -->
  <!-- STEP 1: Read last successful load timestamp from ETL_CONTROL  -->
  <!-- If NULL (first run) returns 1900-01-01 so all rows qualify    -->
  <!-- ============================================================ -->
  <step>
    <name>get_last_load</name>
    <type>TableInput</type>
    <description/>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <connection>warehouse</connection>
    <sql>SELECT
  IFNULL(LastSuccessfulLoad,
         CAST('1900-01-01 00:00:00' AS DATETIME)) AS last_load
FROM ETL_CONTROL
WHERE ProcessName = 'DIM_TIME'</sql>
    <limit>0</limit>
    <lookup/>
    <execute_each_row>N</execute_each_row>
    <variables_active>N</variables_active>
    <lazy_conversion_active>N</lazy_conversion_active>
    <cached_row_meta_active>N</cached_row_meta_active>
    <row-meta>
    </row-meta>
    <attributes/>
    <cluster_schema/>
    <remotesteps>
      <input>
      </input>
      <output>
      </output>
    </remotesteps>
    <GUI>
      <xloc>150</xloc>
      <yloc>200</yloc>
      <draw>Y</draw>
    </GUI>
  </step>

  <!-- ============================================================ -->
  <!-- STEP 2: Extract distinct dates from OLTP                      -->
  <!-- Uses ? parameter from get_last_load (execute_each_row = Y)    -->
  <!-- Total load:  last_load = 1900-01-01 => all rows qualify       -->
  <!-- Incremental: only rows with CreatedAt > last_load             -->
  <!-- ============================================================ -->
  <step>
    <name>extract_dates</name>
    <type>TableInput</type>
    <description/>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <connection>oltp</connection>
    <sql>SELECT DISTINCT
  d.Datum        AS FullDate,
  DAY(d.Datum)   AS DayNumber,
  MONTH(d.Datum) AS MonthNumber,
  MONTHNAME(d.Datum) AS MonthName,
  QUARTER(d.Datum)   AS QuarterNumber,
  YEAR(d.Datum)      AS YearNumber,
  DAYOFWEEK(d.Datum) AS DayOfWeekNumber,
  DAYNAME(d.Datum)   AS DayOfWeekName,
  CASE WHEN DAYOFWEEK(d.Datum) IN (1, 7) THEN 1 ELSE 0 END AS IsWeekend
FROM (
  SELECT Datum, CreatedAt FROM NARUDZBINA
  UNION
  SELECT Datum, CreatedAt FROM RECENZIJA
) d
WHERE d.CreatedAt > ?</sql>
    <limit>0</limit>
    <lookup>get_last_load</lookup>
    <execute_each_row>Y</execute_each_row>
    <variables_active>N</variables_active>
    <lazy_conversion_active>N</lazy_conversion_active>
    <cached_row_meta_active>N</cached_row_meta_active>
    <row-meta>
    </row-meta>
    <attributes/>
    <cluster_schema/>
    <remotesteps>
      <input>
      </input>
      <output>
      </output>
    </remotesteps>
    <GUI>
      <xloc>400</xloc>
      <yloc>200</yloc>
      <draw>Y</draw>
    </GUI>
  </step>

  <!-- ============================================================ -->
  <!-- STEP 3: Insert / Update into warehouse.DIM_TIME               -->
  <!-- Lookup key = FullDate; skip update if row already exists      -->
  <!-- TimeKey is AUTO_INCREMENT, DW_LoadedAt defaults to NOW()      -->
  <!-- ============================================================ -->
  <step>
    <name>insert_update_dim_time</name>
    <type>InsertUpdate</type>
    <description/>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <connection>warehouse</connection>
    <commit>100</commit>
    <update_bypassed>N</update_bypassed>
    <lookup>
      <schema/>
      <table>DIM_TIME</table>
      <key>
        <name>FullDate</name>
        <field>FullDate</field>
        <condition>=</condition>
        <name2/>
      </key>
      <value>
        <name>FullDate</name>
        <rename>FullDate</rename>
        <update>N</update>
      </value>
      <value>
        <name>DayNumber</name>
        <rename>DayNumber</rename>
        <update>N</update>
      </value>
      <value>
        <name>MonthNumber</name>
        <rename>MonthNumber</rename>
        <update>N</update>
      </value>
      <value>
        <name>MonthName</name>
        <rename>MonthName</rename>
        <update>N</update>
      </value>
      <value>
        <name>QuarterNumber</name>
        <rename>QuarterNumber</rename>
        <update>N</update>
      </value>
      <value>
        <name>YearNumber</name>
        <rename>YearNumber</rename>
        <update>N</update>
      </value>
      <value>
        <name>DayOfWeekNumber</name>
        <rename>DayOfWeekNumber</rename>
        <update>N</update>
      </value>
      <value>
        <name>DayOfWeekName</name>
        <rename>DayOfWeekName</rename>
        <update>N</update>
      </value>
      <value>
        <name>IsWeekend</name>
        <rename>IsWeekend</rename>
        <update>N</update>
      </value>
    </lookup>
    <attributes/>
    <cluster_schema/>
    <remotesteps>
      <input>
      </input>
      <output>
      </output>
    </remotesteps>
    <GUI>
      <xloc>650</xloc>
      <yloc>200</yloc>
      <draw>Y</draw>
    </GUI>
  </step>

  <!-- ============================================================ -->
  <!-- STEP 4: Update ETL_CONTROL after loading                      -->
  <!-- ============================================================ -->
  <step>
    <name>update_etl_control</name>
    <type>ExecSQL</type>
    <description/>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <connection>warehouse</connection>
    <execute_each_row>Y</execute_each_row>
    <single_statement>Y</single_statement>
    <replace_variables>N</replace_variables>
    <quoteString>N</quoteString>
    <sql>UPDATE ETL_CONTROL
SET LastSuccessfulLoad = NOW(),
    LastRunStatus      = 'SUCCESS',
    LastRunAt          = NOW()
WHERE ProcessName = 'DIM_TIME'</sql>
    <set_params>N</set_params>
    <insert_field/>
    <update_field/>
    <delete_field/>
    <read_field/>
    <arguments>
    </arguments>
    <attributes/>
    <cluster_schema/>
    <remotesteps>
      <input>
      </input>
      <output>
      </output>
    </remotesteps>
    <GUI>
      <xloc>900</xloc>
      <yloc>200</yloc>
      <draw>Y</draw>
    </GUI>
  </step>

  <step_error_handling>
  </step_error_handling>
  <slave-step-copy-partition-distribution>
  </slave-step-copy-partition-distribution>
  <slave_transformation>N</slave_transformation>
  <attributes/>
</transformation>
